rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Usuarios: solo autenticados pueden leer/escribir
    // Ajusta según necesites (ej: solo admin lee todos)
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    
    // Casos: usuarios autenticados pueden leer/escribir
    match /cases/{caseId} {
      allow read, write: if request.auth != null;
    }
    
    // Credenciales judiciales: solo el dueño puede acceder
    match /users/{userId}/credentials/{credId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
